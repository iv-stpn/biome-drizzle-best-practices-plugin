{
  "name": "biome-drizzle-best-practices-plugin",
  "version": "2.0.1",
  "description": "Biome plugin that enforces Drizzle ORM best practices — join conditions, non-empty .where(), and safe sql.raw usage.",
  "license": "ISC",
  "author": "Ivan Stepanian <iv.stpn@gmail.com>",
  "type": "commonjs",
  "keywords": [
    "biome",
    "biome-plugin",
    "gritql",
    "lint",
    "drizzle",
    "drizzle-orm",
    "database",
    "sql"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iv-stpn/biome-drizzle-best-practices-plugin.git"
  },
  "homepage": "https://github.com/iv-stpn/biome-drizzle-best-practices-plugin#readme",
  "bugs": {
    "url": "https://github.com/iv-stpn/biome-drizzle-best-practices-plugin/issues"
  },
  "files": [
    "drizzle.grit",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": ">=2.5.4",
    "@changesets/cli": "2.31.0",
    "@types/node": "^26",
    "biome-one-liner-plugin": "1.4.0",
    "husky": "9.1.7",
    "typescript": "^7"
  }
}
